---
import CrestLogo from "./CrestLogo.astro";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Engagements" },
  { href: "/charte", label: "Charte des élu·es" },
  { href: "mailto:contact@crest2033.fr", label: "Contact" },
];
---

<header class="bg-white/80 backdrop-blur-md border-b border-avec-gray-light sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="flex flex-col leading-tight">
          <span class="text-xs font-semibold tracking-widest uppercase text-avec-terracotta">
            crest2033.fr
          </span>
          <div class="flex items-center gap-2">
            <span class="text-xl sm:text-2xl font-extrabold text-avec-dark font-heading">
              AVEC
            </span>
            <CrestLogo class="w-20 sm:w-24 -mt-1" />
          </div>
        </div>
      </a>

      <nav class="flex items-center gap-1 sm:gap-2">
        {navItems.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors",
              currentPath === href
                ? "bg-avec-terracotta text-white"
                : "text-avec-dark-light hover:bg-avec-warm hover:text-avec-terracotta",
            ]}
          >
            {label}
          </a>
        ))}
        <a
          href="https://github.com/elishowk/crest2033/fork"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 px-3 py-2 rounded-lg text-sm font-semibold bg-avec-green text-white hover:bg-avec-green-dark transition-colors hidden sm:inline-flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor">
            <path fill-rule="evenodd" d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878zm3.75 7.378a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm3-8.75a.75.75 0 100-1.5.75.75 0 000 1.5z" />
          </svg>
          Proposer une amélioration
        </a>
      </nav>
    </div>
  </div>
</header>
