---
import CrestLogo from "./CrestLogo.astro";

const currentPath = Astro.url.pathname;
const navItems = [
  { href: "/", label: "Engagements" },
  { href: "/charte", label: "Charte des élu·es" },
];
---

<header class="bg-white/80 backdrop-blur-md border-b border-avec-gray-light sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 sm:h-20">
      <a href="/" class="flex items-center gap-3 group">
        <div class="flex flex-col leading-tight">
          <span class="text-xs font-semibold tracking-widest uppercase text-avec-terracotta">
            Suivi des engagements
          </span>
          <div class="flex items-center gap-2">
            <span class="text-xl sm:text-2xl font-extrabold text-avec-dark font-heading">
              AVEC
            </span>
            <CrestLogo class="w-20 sm:w-24 -mt-1" />
          </div>
        </div>
      </a>

      <nav class="flex items-center gap-1 sm:gap-2">
        {navItems.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "px-3 py-2 rounded-lg text-sm font-medium transition-colors",
              currentPath === href
                ? "bg-avec-terracotta text-white"
                : "text-avec-dark-light hover:bg-avec-warm hover:text-avec-terracotta",
            ]}
          >
            {label}
          </a>
        ))}
        <a
          href="https://www.crest2026.fr/"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-2 px-3 py-2 rounded-lg text-sm font-medium text-avec-green hover:bg-avec-green/10 transition-colors hidden sm:inline-flex items-center gap-1"
        >
          crest2026.fr
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.75a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V6.31l-5.47 5.47a.75.75 0 01-1.06-1.06l5.47-5.47H12.25a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
          </svg>
        </a>
      </nav>
    </div>
  </div>
</header>
