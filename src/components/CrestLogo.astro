---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class:list={["crest-logo inline-block", className]}>
  <svg viewBox="0 0 360 100" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <defs>
      <linearGradient id="loopGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#C75B2A" />
        <stop offset="50%" stop-color="#E9C46A" />
        <stop offset="100%" stop-color="#2D6A4F" />
      </linearGradient>
    </defs>
    <!-- Loop/lemniscate over "Crest" -->
    <path
      d="M80,28 C80,12 110,4 140,16 C160,24 170,10 180,10 C190,10 200,24 220,16 C250,4 280,12 280,28 C280,44 250,48 220,38 C200,30 190,44 180,44 C170,44 160,30 140,38 C110,48 80,44 80,28 Z"
      fill="none"
      stroke="url(#loopGradient)"
      stroke-width="3"
      stroke-linecap="round"
      class="loop-path"
    />
    <!-- "Crest" text -->
    <text
      x="180"
      y="80"
      text-anchor="middle"
      font-family="'Bricolage Grotesque', sans-serif"
      font-weight="800"
      font-size="52"
      fill="#2B2D42"
      letter-spacing="-1"
    >
      Crest
    </text>
  </svg>
</div>

<style>
  .loop-path {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: drawLoop 2s ease-out forwards;
  }

  @keyframes drawLoop {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
