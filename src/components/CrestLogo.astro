---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class:list={["crest-logo inline-block", className]}>
  <svg viewBox="0 0 280 80" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
    <defs>
      <linearGradient id="loopGradient" x1="0%" y1="0%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#C75B2A" />
        <stop offset="50%" stop-color="#E9C46A" />
        <stop offset="100%" stop-color="#2D6A4F" />
      </linearGradient>
    </defs>
    <path
      d="M55,22 C55,10 78,4 100,13 C115,19 123,8 133,8 C143,8 151,19 166,13 C188,4 211,10 211,22 C211,34 188,37 166,29 C151,23 143,34 133,34 C123,34 115,23 100,29 C78,37 55,34 55,22 Z"
      fill="none"
      stroke="url(#loopGradient)"
      stroke-width="2.5"
      stroke-linecap="round"
      class="loop-path"
    />
    <text
      x="140"
      y="64"
      text-anchor="middle"
      font-family="'Bricolage Grotesque', sans-serif"
      font-weight="800"
      font-size="38"
      fill="#2B2D42"
      letter-spacing="-0.5"
    >
      Crest 2033
    </text>
  </svg>
</div>

<style>
  .loop-path {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
    animation: drawLoop 2s ease-out forwards;
  }

  @keyframes drawLoop {
    to {
      stroke-dashoffset: 0;
    }
  }
</style>
