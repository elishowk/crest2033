---
interface Props {
  term: string;
}
const { term } = Astro.props;
---

<div class="mt-8 pt-8 border-t border-avec-gray-light">
  <h3 class="font-heading font-bold text-lg text-avec-dark mb-4">
    Commentaires et discussions
  </h3>
  <div id="giscus-container" data-term={term}>
    <div class="bg-avec-warm rounded-xl p-6 text-center">
      <p class="text-avec-dark-light text-sm mb-3">
        Les commentaires utilisent GitHub Discussions.
      </p>
      <p class="text-avec-gray text-xs mb-4">
        Pour activer les commentaires, configurez Giscus avec votre dépôt GitHub dans
        <code class="bg-white px-1.5 py-0.5 rounded text-xs">src/components/Comments.astro</code>.
      </p>
      <a
        href="https://giscus.app/fr"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm text-avec-terracotta font-medium hover:underline"
      >
        Configurer Giscus
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M4.25 5.5a.75.75 0 00-.75.75v8.5c0 .414.336.75.75.75h8.5a.75.75 0 00.75-.75v-4a.75.75 0 011.5 0v4A2.25 2.25 0 0112.75 17h-8.5A2.25 2.25 0 012 14.75v-8.5A2.25 2.25 0 014.25 4h5a.75.75 0 010 1.5h-5zm7.25-.75a.75.75 0 01.75-.75h3.5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0V6.31l-5.47 5.47a.75.75 0 01-1.06-1.06l5.47-5.47H12.25a.75.75 0 01-.75-.75z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</div>

<!--
  To enable Giscus comments, replace the placeholder above with:

  <script
    src="https://giscus.app/client.js"
    data-repo="YOUR_GITHUB_USER/YOUR_REPO"
    data-repo-id="YOUR_REPO_ID"
    data-category="Comments"
    data-category-id="YOUR_CATEGORY_ID"
    data-mapping="specific"
    data-term={term}
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="light"
    data-lang="fr"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  />
-->
