---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PromiseCard from "../components/PromiseCard.astro";
import GlobalProgress from "../components/GlobalProgress.astro";

const promesses = (await getCollection("promesses")).sort(
  (a, b) => a.data.order - b.data.order,
);

const allActions = promesses.flatMap((p) => p.data.actions);
const totalActions = allActions.length;
const doneActions = allActions.filter((a) => a.done).length;
const inProgressPromises = promesses.filter(
  (p) => p.data.status === "en-cours" || p.data.status === "avancee",
).length;
---

<Layout title="Suivi des engagements">
  <section class="bg-gradient-to-br from-avec-warm via-white to-avec-cream py-12 sm:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading font-extrabold text-3xl sm:text-5xl text-avec-dark leading-tight mb-4">
          Suivi des engagements
          <span class="text-avec-terracotta">AVEC</span>
        </h1>
        <p class="text-lg text-avec-dark-light leading-relaxed mb-2">
          Suivez l'avancée des promesses de campagne de la liste
          <strong>AVEC — Agir et Vivre Ensemble à Crest</strong>,
          majorité municipale élue en mars 2026.
        </p>
        <p class="text-sm text-avec-gray">
          Ce site citoyen et collaboratif permet de suivre, commenter et voter
          pour les engagements qui vous tiennent à cœur.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-10 mb-12">
    <GlobalProgress
      total={totalActions}
      done={doneActions}
      inProgress={inProgressPromises}
    />
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="font-heading font-bold text-2xl text-avec-dark mb-8">
      Les engagements du programme
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {promesses.map((promesse) => (
        <PromiseCard
          id={promesse.id}
          title={promesse.data.title}
          icon={promesse.data.icon}
          description={promesse.data.description}
          progress={promesse.data.progress}
          status={promesse.data.status}
          actions={promesse.data.actions}
        />
      ))}
    </div>
  </section>
</Layout>
